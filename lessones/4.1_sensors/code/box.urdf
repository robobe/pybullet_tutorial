<?xml version="1.0"?>
<robot name="simple_box">

  <link name="base_link">

    <!-- Mass and inertia -->
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0"/>
      <inertia
        ixx="0.0067"
        iyy="0.0067"
        izz="0.0067"
        ixy="0"
        ixz="0"
        iyz="0"/>
    </inertial>

    <!-- Collision shape (physics) -->
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.2 0.2 0.2"/>
      </geometry>
    </collision>

    <!-- Visual shape -->
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.2 0.2 0.2"/>
      </geometry>
      <material name="green">
        <color rgba="0 1 0 1"/>
      </material>
    </visual>

  </link>

</robot>